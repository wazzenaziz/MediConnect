SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Email (Resend) — used to send the doctor-welcome email on account creation.
# Get an API key at https://resend.com. EMAIL_FROM must be a verified sender
# (or use the sandbox onboarding@resend.dev for testing). If RESEND_API_KEY is
# unset, email sends are skipped (logged) and doctor creation still succeeds.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=MediConnect <onboarding@resend.dev>

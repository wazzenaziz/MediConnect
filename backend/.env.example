SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# AI symptom triage (required for the /api/triage feature).
# Free key at https://console.groq.com. Uses Llama 3.3 70B via Groq's
# OpenAI-compatible endpoint. If unset, triage requests will fail.
GROQ_API_KEY=your_groq_api_key

# Email (Resend) — used to send the doctor-welcome email on account creation.
# Get an API key at https://resend.com. EMAIL_FROM must be a verified sender
# (or use the sandbox onboarding@resend.dev for testing). If RESEND_API_KEY is
# unset, email sends are skipped (logged) and doctor creation still succeeds.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=MediConnect <onboarding@resend.dev>
